    "def get_sublevel_complex(image, threshold):\n",
    "    n = image.shape[0]\n",
    "    \n",
    "    vertices = []\n",
    "    edges = []\n",
    "    squares = []\n",
    "    \n",
    "    # Vertices (0-cubes)\n",
    "    for i in range(n):\n",
    "        for j in range(n):\n",
    "            if image[i, j] <= threshold:\n",
    "                vertices.append((i, j))\n",
    "    \n",
    "    # Horizontal edges\n",
    "    for i in range(n):\n",
    "        for j in range(n-1):\n",
    "            if image[i,j] <= threshold and image[i,j+1] <= threshold:\n",
    "                edges.append(((i,j), (i,j+1)))\n",
    "    \n",
    "    # Vertical edges\n",
    "    for i in range(n-1):\n",
    "        for j in range(n):\n",
    "            if image[i,j] <= threshold and image[i+1,j] <= threshold:\n",
    "                edges.append(((i,j), (i+1,j)))\n",
    "    \n",
    "    # Squares (2-cubes)\n",
    "    for i in range(n-1):\n",
    "        for j in range(n-1):\n",
    "            if (image[i,j] <= threshold and\n",
    "                image[i+1,j] <= threshold and\n",
    "                image[i,j+1] <= threshold and\n",
    "                image[i+1,j+1] <= threshold):\n",
    "                squares.append(((i,j), (i+1,j), (i,j+1), (i+1,j+1)))\n",
    "    \n",
    "    return vertices, edges, squares"
   ]
  },
