    "import numpy as np\n",
    "import gudhi as gd\n",
    "import matplotlib.pyplot as plt\n",
    "from PIL import Image\n",
    "\n",
    "def PD(image):\n",
    " \n",
    "\n",
    "    # Build cubical complex from pixel values\n",
    "    cc = gd.CubicalComplex(top_dimensional_cells=image)\n",
    "\n",
    "    # Compute persistence\n",
    "    cc.compute_persistence()\n",
    "\n",
    "    diag = cc.persistence()\n",
    "    return diag\n"
   ]
  },
